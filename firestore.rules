rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Rules
    match /posts/{post} {
      allow read, write: if true;
    }

    match /purposes/{purposeId} {
      allow read: if true; 
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    match /logs/{logId} {
      // Anyone can create a log
      allow create: if request.resource.data.ownerId != null;

      // Only the owner (admin) can list/read all logs
      allow read: if isAuthenticated() && resource.data.ownerId == request.auth.uid;

      allow update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if true;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // AI Service Results
    match /photoAnalysis/{docId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /assessments/{docId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /healthSafetyPlans/{docId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /managementFeePlans/{docId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /safetyChecklists/{docId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /safety_logs/{docId} {
      allow create: if isAuthenticated() && request.resource.data.managerId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.managerId == request.auth.uid;
    }

    // 안전관리자 할 일 (TO DO LIST) — 로그인 사용자 본인 managerId만
    match /safety_manager_todos/{docId} {
      allow create: if isAuthenticated() && request.resource.data.managerId == request.auth.uid;
      allow get, list: if isAuthenticated() && resource.data.managerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.managerId == request.auth.uid;
    }

    match /contractor_partners/{docId} {
      allow create: if isAuthenticated() && request.resource.data.managerId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.managerId == request.auth.uid;
    }

    // 회의록(산업안전보건위원회 / 협력업체 협의체 / 기타)
    match /meeting_minutes/{docId} {
      allow create: if isAuthenticated() && request.resource.data.managerId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.managerId == request.auth.uid;
    }

    match /contractor_partner_eval_criteria/{userId} {
      // 본인 경로(userId == auth.uid)인 경우에만 접근 허용.
      // read 는 문서가 존재하지 않아도 통과해야 하므로 resource.data 검사는 하지 않음.
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.managerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && request.auth.uid == userId && resource.data.managerId == request.auth.uid;
    }

    // 근로자 의견청취: 관리자별 안내 HTML (공개 조회는 제출 페이지용)
    match /worker_feedback_settings/{userId} {
      allow get: if true;
      allow create, update, delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // 근로자 의견 제출 (비로그인 제출 허용, 관리자만 열람·삭제)
    match /worker_feedback_submissions/{docId} {
      allow create: if request.resource.data.managerId is string
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 20000;
      allow read, delete: if isAuthenticated() && resource.data.managerId == request.auth.uid;
      // 관리자만 확인(acknowledged) 처리 — 변경 허용 필드는 acknowledged / acknowledgedAt 뿐
      // (authorName·department 등 선택 필드 누락 시 == 비교가 실패하므로 MapDiff 사용)
      allow update: if isAuthenticated()
        && resource.data.managerId == request.auth.uid
        && request.resource.data.managerId == resource.data.managerId
        && request.resource.data.body == resource.data.body
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['acknowledged', 'acknowledgedAt']);
    }
  }
}
